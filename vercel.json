{
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/resize",
      "destination": "https://bispoke-resize-lp.vercel.app/"
    },
    {
      "source": "/resize/:path*",
      "destination": "https://bispoke-resize-lp.vercel.app/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/remodel",
      "destination": "https://retold.tokyo",
      "permanent": false
    },
    {
      "source": "/remodel/:path*",
      "destination": "https://retold.tokyo",
      "permanent": false
    }
  ]
}